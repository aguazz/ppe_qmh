f <- function(t, s, y) {
factor <- sqrt(2 * pi * (1 - t) / (1 - s) * (t - s))
if (is.nan(factor) || factor == 0) return(0)
exponent <- -((b(t) - (1 - t) / (1 - s) * y)^2) / (2 * (1 - t) / (1 - s) * (t - s))
return(1 / factor * exp(exponent))
}
# Volterra Kernel function K with singularity handling
K <- function(t, s, y) {
if (t == s) {
return(0) # Avoid singularity by returning 0 when t == tau
}
term1 <- 0.5 * (b_0_prime(t) - (b_0(t) - y) / (t - s))
return(term1 * f(t, s, y))
}
hitting_density <- function(t0 = 0, x0 = 0, n = 5000, T = 1) {
if(x0 > b_0(x0)) return(c(1, rep(0, n)))
dt <- T / n # time steps
time_grid <- seq(t0, T, by = dt) # time grid
# Initialize solution for f_x0_t0(t)
dens <- numeric(n+1)
# Numerical integration (trapezoidal rule)
for (i in 3:(n+1)) {
cat(paste0("t = ", time_grid[i], "\r"))
t <- time_grid[i]
# Compute the kernel K(s, t0, x0) at this point
K_t <- K(t, t0, x0)
# Initialize integral sum
integral_sum <- 0
# Compute the integral part
u <- time_grid[2:(i-1)]
g_u <- dens[2:(i-1)]
K_u <- sapply(time_grid[2:(i-1)], function(s) K(t, s, b_0(s)))
integral_sum <- integral_sum + sum(g_u * K_u * dt)
# Update dens(t) using the integral equation
dens[i] <- -2 * K_t + 2 * integral_sum
}
return(dens)
}
# Function to compute the moments \tau^n b(\tau)
moments <- function(n, dt = 0.0001, t0 = 0, t1 = 1, hitting_density_fun){
time_grid <- seq(t0, t1, by = dt)
f_t <- hitting_density_fun(time_grid)
index <- !is.nan(f_t)
t_n <- time_grid^n
b_t <- b_0(time_grid)
return(sum(t_n[index] * b_t[index] * f_t[index]*dt))
}
# Value function of the non-discounted problem ### IMPROVE THE PRECISION OF B
V_0 <- function(x){
if (x < 0.8399) {
return(sqrt(2*pi)*(1-0.8399^2)*exp(x^2/2)*pnorm(x))
} else {
return(x)
}
}
# Taylor expansion of the boundary with discount r evaluated at 0
V_r <- function(x, r, N, hitting_density_fun){
moments_N <- sapply(1:N, function(n) moments(n = n, hitting_density_fun = hitting_density_fun))
V <- sum( (-r)^(0:N)/factorial(0:N) * c(V_0(x), moments_N) )
return(V)
}
# Fixed point algorithm to find b_r
b_r <- function(r, tol = 1e-5, N, b_0, n) {
b_r <- 0
e <- 1
while (e > tol) {
b_r_old <- b_r
f_hitting <- hitting_density(t0 = 0, x0 = b_r_old, n = n, T = 1)
hitting_density_fun <- splinefun(seq(0, 1, by = T/n), f_hitting)
b_r <- V_r(x = b_r_old, r = r, N = N, hitting_density = hitting_density_fun)
e <- abs(b_r_old - b_r)
cat(paste0("error: ", e, " \n"))
}
return(b_r)
}
