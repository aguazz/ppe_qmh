# Boundary b_0 for the discounted case
b_0 <- function(t) { 0.8399 * sqrt(1 - t) }
# Derivative of b_0(t)
b_0_prime <- function(t) {
if (t == 1) return(Inf)  # Avoid division by zero at t = 1
return(-0.8399 / (2 * sqrt(1 - t)))
}
# Transition density Brownian bridge from (s, y) to (t, x)
f <- function(t, s, y) {
factor <- sqrt(2 * pi * (1 - t) / (1 - s) * (t - s))
if (is.nan(factor) || factor == 0) return(0)
exponent <- -((b(t) - (1 - t) / (1 - s) * y)^2) / (2 * (1 - t) / (1 - s) * (t - s))
return(1 / factor * exp(exponent))
}
