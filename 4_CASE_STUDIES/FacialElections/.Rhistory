f1 <- dnorm(x_range, mean = mu, sd = sigma)
# Evaluate the provided f2 function
f2_values <- f2(x_range)
# Compute the denominator (normalization constant)
denominator <- sum(f1 * f2_values) * diff(range(x_range)) / length(x_range)
# Compute f_3
f3 <- (f1 * f2_values) / denominator
# Compute mean f_3
f3_mean <- sum(x_range * f1 * f2_values) * diff(range(x_range)) / length(x_range) / denominator
# Compute second moment f_3
f3_m2 <- sum(x_range^2 * f1 * f2_values) * diff(range(x_range)) / length(x_range) / denominator
# Compute variance moment f_3
f3_var <- f3_m2 - f3_mean^2
return(list(density = f3, mean = f3_mean, variance = f3_var))
}
