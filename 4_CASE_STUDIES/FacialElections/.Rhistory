library(qss)
data("face", package = "qss")
# Chunk 3
summary(face)
## two-party vote share for Democrats and Republicans
face$d.share <- face$d.votes / (face$d.votes + face$r.votes)
face$r.share <- face$r.votes / (face$d.votes + face$r.votes)
face$diff.share <- face$d.share - face$r.share
plot(face$d.comp, face$diff.share, pch = 16,
col = ifelse(face$w.party == "R", "red", "blue"),
xlim = c(0, 1), ylim = c(-1, 1),
xlab = "Competence scores for Democrats",
ylab = "Democratic margin in vote share",
main = "Facial competence and vote share")
plot(face$d.comp, face$diff.share, pch = 16,
col = ifelse(face$w.party == "R", "red", "blue"),
xlim = c(0, 1), ylim = c(-1, 1),
xlab = "Competence scores for Democrats",
ylab = "Democratic margin in vote share",
main = "Facial competence and vote share")
# Generate example datasets with varying correlations
set.seed(123)
x <- seq(-3, 3, length.out = 100)
y1 <- x + rnorm(100, sd = 0.5)  # Positive correlation
y2 <- -x + rnorm(100, sd = 0.5) # Negative correlation
y3 <- rnorm(100)                # No correlation
y4 <- x^2 + rnorm(100, sd = 0.2) # Nonlinear relationship
# Create scatter plots
par(mfrow = c(2, 2))
plot(x, y1, main = "Positive Correlation", xlab = "X", ylab = "Y")
plot(x, y2, main = "Negative Correlation", xlab = "X", ylab = "Y")
plot(x, y3, main = "No Correlation", xlab = "X", ylab = "Y")
plot(x, y4, main = "Nonlinear Relationship", xlab = "X", ylab = "Y")
