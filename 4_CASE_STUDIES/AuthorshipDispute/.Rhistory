dens_churn <- density(training$tenure[training$Churn == "Yes"])
plot(dens_stay, ylim = range(dens_stay$y, dens_churn$y),
main = "Tenure by churn status", col = pal3[1],
xlab = "Tenure (months)", lwd = 2)
lines(dens_churn, lwd = 2, lty = 1, col = pal3[2])
legend("topright", legend = c("Stayed", "Churned"),
lwd = 2, lty = c(1, 1), bty = "n", col = pal3[1:2])
par(op)
op <- par(mfrow = c(1, 2), mar = c(3, 4.5, 2, 0.5))
boxplot(MonthlyCharges ~ Churn, data = training,
xlab = "Churn", ylab = "Monthly charges",
main = "Monthly charges vs churn", col = pal3[1:2])
dens_low  <- density(training$MonthlyCharges[training$Churn == "No"])
dens_high <- density(training$MonthlyCharges[training$Churn == "Yes"])
plot(dens_low, ylim = range(dens_low$y, dens_high$y),
main = "Monthly charges by churn status",
xlab = "Monthly charges", lwd = 2, col = pal3[1])
lines(dens_high, lwd = 2, lty = 1, col = pal3[2])
legend("topright", legend = c("Stayed", "Churned"),
lwd = 2, lty = c(1, 1), bty = "n", col = pal3[1:2])
par(op)
# Contract vs Churn
tab_contract <- table(training$Contract, training$Churn)
tab_contract
barplot(tab_contract,
beside = TRUE,
legend = TRUE,
xlab = "Contract type",
ylab = "Number of customers",
main = "Churn by contract type")
# Online security vs Churn
tab_security <- table(training$OnlineSecurity, training$Churn)
tab_security
barplot(tab_security,
beside = TRUE,
legend = TRUE,
