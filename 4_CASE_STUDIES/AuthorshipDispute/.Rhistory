main = "Churn by online security")
numeric_cols <- sapply(training, is.numeric)
cor_mat <- cor(training[, numeric_cols])
round(cor_mat, 2)
if ("TotalCharges" %in% names(training)) {
training$TotalCharges <- NULL
testing$TotalCharges  <- NULL
}
# Majority class in the training data
tab_churn <- table(training$Churn)
tab_churn
majority_class <- names(which.max(tab_churn))
majority_class
naive_pred <- factor(rep(majority_class, nrow(testing)),
levels = levels(testing$Churn))
naive_cm <- confusionMatrix(naive_pred, testing$Churn)
naive_cm
# Ensure Churn is a factor (it should already be)
training$Churn <- factor(training$Churn)
testing$Churn  <- factor(testing$Churn)
logit_model <- glm(Churn ~ ., data = training, family = binomial)
summary(logit_model)
exp(coef(logit_model))
logit_prob <- predict(logit_model, newdata = testing, type = "response")
summary(logit_prob)
logit_pred_0.5 <- ifelse(logit_prob > 0.5, "Yes", "No")
logit_pred_0.5 <- factor(logit_pred_0.5, levels = levels(testing$Churn))
logit_cm_0.5 <- confusionMatrix(logit_pred_0.5, testing$Churn)
logit_cm_0.5
naive_cm$overall["Accuracy"]
logit_cm_0.5$overall["Accuracy"]
roc_obj <- roc(response  = testing$Churn,
predictor = logit_prob,
levels   = rev(levels(testing$Churn)))  # "Yes" as positive
plot(roc_obj, main = "ROC curve: logistic regression")
auc(roc_obj)
# We assume:
#  - logit_prob  : predicted probability of churn on the test set
#  - testing$Churn: factor with levels c("No","Yes")
# Build a small data frame for convenience (no tidyverse)
lift_data <- data.frame(
prob  = logit_prob,
churn = ifelse(testing$Churn == "Yes", 1, 0)
)
# Order customers by predicted probability (descending)
ord <- order(lift_data$prob, decreasing = TRUE)
lift_data <- lift_data[ord, ]
n      <- nrow(lift_data)
n_pos  <- sum(lift_data$churn)  # total number of churners in the test set
# Define percentiles (top 10%, 20%, ..., 100%)
percentiles <- seq(0.1, 1.0, by = 0.1)
cut_points  <- floor(percentiles * n)
# Cumulative number of churners captured at each observation
cum_churners <- cumsum(lift_data$churn)
# For each percentile, compute the fraction of churners captured ("gain")
gain <- cum_churners[cut_points] / n_pos
# Baseline (random model) would capture churners in proportion to customers targeted
baseline <- percentiles
# Plot cumulative gains (lift curve)
plot(c(0,percentiles), c(0,gain),
type = "b",
xlab = "Proportion of customers targeted",
ylab = "Proportion of churners captured",
main = "Lift (cumulative gains) curve: logistic regression",
ylim = c(0, 1))
# Add random-model baseline
lines(c(0,percentiles), c(0,baseline), lty = 2)
legend("bottomright",
legend = c("Logistic regression", "Random model"),
lty    = c(1, 2),
bty    = "n")
lift_values <- gain / baseline
data.frame(
Percent_customers_targeted = percentiles,
Gain_churners              = round(gain, 3),
Lift                        = round(lift_values, 2)
)
cost_unit <- c(0, 100, 500, 140)
cost_unit
cm_naive <- naive_cm$table
cm_naive
cost_naive <- sum(as.vector(cm_naive) * cost_unit) / sum(cm_naive)
cost_naive
cm_logit_0.5 <- logit_cm_0.5$table
cm_logit_0.5
cost_logit_0.5 <- sum(as.vector(cm_logit_0.5) * cost_unit) / sum(cm_logit_0.5)
cost_logit_0.5
threshold <- 0.3
logit_pred_0.3 <- ifelse(logit_prob > threshold, "Yes", "No")
logit_pred_0.3 <- factor(logit_pred_0.3, levels = levels(testing$Churn))
logit_cm_0.3 <- confusionMatrix(logit_pred_0.3, testing$Churn)
logit_cm_0.3
cm_logit_0.3 <- logit_cm_0.3$table
cost_logit_0.3 <- sum(as.vector(cm_logit_0.3) * cost_unit) / sum(cm_logit_0.3)
cost_logit_0.3
c(
Naive          = cost_naive,
Logit_thr_0.5  = cost_logit_0.5,
Logit_thr_0.3  = cost_logit_0.3
)
# Grid of candidate thresholds
threshold_grid <- seq(0.05, 0.5, by = 0.01)
# We re-fit the logistic regression inside each CV fold using the SAME formula as before.
# (Fallbacks are included in case your object name differs.)
form_logit <- if (exists("fit_logit_step")) {
formula(fit_logit_step)
} else if (exists("fit_logit")) {
formula(fit_logit)
} else if (exists("logit_fit")) {
formula(logit_fit)
} else {
Churn ~ .
}
# K-fold CV on the TRAINING set (stratified)
set.seed(123)
K <- 5
folds <- caret::createFolds(training$Churn, k = K, returnTrain = FALSE)
# Store cost per threshold and fold
cost_cv <- matrix(NA_real_, nrow = length(threshold_grid), ncol = K)
for (f in seq_along(folds)) {
idx_val <- folds[[f]]
tr  <- training[-idx_val, ]
val <- training[ idx_val, ]
# Fit model on fold-training
fit_cv <- glm(form_logit, data = tr, family = binomial)
# Predict probabilities on fold-validation
prob_val <- predict(fit_cv, newdata = val, type = "response")
# Compute cost curve over thresholds for this fold
for (i in seq_along(threshold_grid)) {
thr <- threshold_grid[i]
pred_thr <- ifelse(prob_val > thr, "Yes", "No")
pred_thr <- factor(pred_thr, levels = levels(val$Churn))
cm_thr <- confusionMatrix(pred_thr, val$Churn)$table
cost_cv[i, f] <- sum(as.vector(cm_thr) * cost_unit) / sum(cm_thr)
}
}
# Aggregate across folds
cost_mean <- rowMeans(cost_cv)
best_index     <- which.min(cost_mean)
best_threshold <- threshold_grid[best_index]
best_cv_cost   <- cost_mean[best_index]
best_threshold
best_cv_cost
# Boxplots of CV cost per threshold
par(mar = c(9, 4, 4, 2) + 0.1)
boxplot(as.data.frame(t(cost_cv)), col = "lightblue",
names = sprintf("%.2f", threshold_grid),
las = 2, cex.axis = 0.6,
xlab = "Probability threshold",
ylab = "Average cost per customer (CV folds)",
main = "Cost vs threshold (logit, 5-fold CV)")
abline(v = best_index, lty = 2)
logit_pred_best <- ifelse(logit_prob > best_threshold, "Yes", "No")
logit_pred_best <- factor(logit_pred_best, levels = levels(testing$Churn))
logit_cm_best <- confusionMatrix(logit_pred_best, testing$Churn)
logit_cm_best
cm_best   <- logit_cm_best$table
cost_best <- sum(as.vector(cm_best) * cost_unit) / sum(cm_best)
cost_best
# Ensure consistent class order (positive class = "Yes")
training$Churn <- factor(training$Churn, levels = c("No", "Yes"))
testing$Churn  <- factor(testing$Churn,  levels = c("No", "Yes"))
# Custom loss (lower is better)
EconomicCost <- function(data, lev = NULL, model = NULL) {
CM <- caret::confusionMatrix(data$pred, data$obs)$table
out <- sum(as.vector(CM) * cost_unit) / sum(CM)
c(EconomicCost = out)
}
# Model: logistic regression, but caret will tune the THRESHOLD via "prob" model
set.seed(123)
ctrl_cost <- caret::trainControl(
method = "cv", number = 5,
classProbs = TRUE,
summaryFunction = EconomicCost,
savePredictions = "final"
)
# Tune over thresholds (caret uses "threshold" as the tuning parameter for this method)
thr_grid <- expand.grid(threshold = seq(0.05, 0.5, by = 0.01))
fit_logit_thr <- caret::train(
Churn ~ ,
fit_logit_thr <- caret::train(
Churn ~ .,
data = training,
method = "glm",
family = binomial,
metric = "EconomicCost",
maximize = FALSE,
trControl = ctrl_cost,
tuneGrid = thr_grid
)
View(tree_prob_mat)
optimizer using out-of-fold probabilities saved by caret
